# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Tool caches
.pytest_cache/
.ruff_cache/

# macOS
.DS_Store
**/.DS_Store

# Runs & results data (large/sensitive)
runs.jsonl
results.json
experiments/results_v1/

# Un-ignore static copies bundled for Render Docker build
!capstone-website/backend/static_data/**

# API keys & secrets
.env
.env.local
secrets.*
*api_key*

# R
.Rhistory
.RData
*.Rproj.user/

# Node
node_modules/
.next/
capstone-website/frontend/dist/

# Large binary files
literature/*.pdf
literature/**/*.pdf
figures/*.gif
interactive/
**/*.gif

# Allow website public assets (Vercel needs these)
!capstone-website/frontend/public/visualizations/interactive/
!capstone-website/frontend/public/visualizations/interactive/**
!capstone-website/frontend/public/visualizations/png/15_bar_race.gif

# IDE
.vscode/
.idea/
.claude/
benchmark_report.html
report_materials/r_analysis/benchmark_report.html
.vercel

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.toc
paper/*.pdf
paper/sections/*.aux
paper/main.synctex.gz
